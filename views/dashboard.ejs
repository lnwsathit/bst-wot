<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Work Order Tracking</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f5f7fa;
            color: #333;
        }

        .container {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 250px;
            background: white;
            box-shadow: 2px 0 8px rgba(0, 0, 0, 0.08);
            padding: 20px;
            position: fixed;
            height: 100vh;
            overflow-y: auto;
        }

        .sidebar-header {
            font-size: 18px;
            font-weight: 700;
            color: #667eea;
            margin-bottom: 30px;
            text-align: center;
        }

        .nav-item {
            display: block;
            padding: 12px 16px;
            margin-bottom: 8px;
            color: #666;
            text-decoration: none;
            border-radius: 8px;
            transition: all 0.3s;
            font-size: 14px;
        }

        .nav-item:hover {
            background: #f0f4ff;
            color: #667eea;
        }

        .nav-item.active {
            background: #667eea;
            color: white;
        }

        .nav-logout {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #e0e0e0;
        }

        .main-content {
            margin-left: 250px;
            flex: 1;
            padding: 30px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .header h1 {
            font-size: 28px;
            color: #333;
        }

        .user-info {
            text-align: right;
        }

        .user-info p {
            font-size: 14px;
            color: #666;
        }

        .user-info strong {
            color: #333;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
        }

        .stat-label {
            font-size: 14px;
            color: #666;
            margin-bottom: 10px;
        }

        .stat-value {
            font-size: 32px;
            font-weight: 700;
            color: #667eea;
        }

        .stat-icon {
            font-size: 24px;
            margin-bottom: 10px;
        }

        .action-button {
            display: inline-block;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 12px 24px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            transition: transform 0.2s;
        }

        .action-button:hover {
            transform: translateY(-2px);
        }

        .recent-section {
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }

        .section-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 20px;
            color: #333;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: #f5f7fa;
        }

        th {
            padding: 12px;
            text-align: left;
            font-weight: 600;
            color: #666;
            border-bottom: 2px solid #e0e0e0;
            font-size: 13px;
        }

        td {
            padding: 12px;
            border-bottom: 1px solid #e0e0e0;
            font-size: 14px;
        }

        tbody tr:hover {
            background: #f9fafb;
        }

        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-quotation {
            background: #fff3cd;
            color: #856404;
        }

        .status-po-customer {
            background: #cfe2ff;
            color: #084298;
        }

        .status-po-supplier {
            background: #cff4fc;
            color: #055160;
        }

        .status-invoice {
            background: #d1e7dd;
            color: #0f5132;
        }

        .status-completed {
            background: #d1e7dd;
            color: #0f5132;
        }

        .action-btn {
            padding: 6px 12px;
            background: #667eea;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 12px;
            text-decoration: none;
            transition: background 0.3s;
        }

        .action-btn:hover {
            background: #764ba2;
        }

        @media (max-width: 768px) {
            .sidebar {
                width: 0;
                padding: 0;
            }

            .main-content {
                margin-left: 0;
            }

            .header {
                flex-direction: column;
                align-items: flex-start;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="sidebar">
            <div class="sidebar-header">📊 WOT System</div>
            <a href="/dashboard" class="nav-item active">Dashboard</a>
            <a href="/workorder" class="nav-item">Work Orders</a>
            <% if (user.role==='Admin' ) { %>
                <a href="/users" class="nav-item">Users Management</a>
                <% } %>
                    <div class="nav-logout">
                        <a href="/api/auth/logout" class="nav-item">Logout</a>
                    </div>
        </div>

        <div class="main-content">
            <div class="header">
                <div>
                    <h1>Dashboard</h1>
                </div>
                <div class="user-info">
                    <p>Welcome, <strong>
                            <%= user.full_name %>
                        </strong></p>
                    <p style="font-size: 12px; color: #999;">
                        <%= user.role %>
                    </p>
                </div>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon">📋</div>
                    <div class="stat-label">Total Work Orders</div>
                    <div class="stat-value" id="totalOrders">0</div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">⏳</div>
                    <div class="stat-label">In Progress</div>
                    <div class="stat-value" id="inProgress">0</div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">✅</div>
                    <div class="stat-label">Completed</div>
                    <div class="stat-value" id="completed">0</div>
                </div>
            </div>

            <div>
                <a href="/workorder" class="action-button">+ Create New Work Order</a>
            </div>

            <div class="recent-section" style="margin-top: 30px;">
                <h2 class="section-title">Recent Work Orders</h2>
                <table>
                    <thead>
                        <tr>
                            <th>Quotation No</th>
                            <th>Customer</th>
                            <th>Status</th>
                            <th>Last Update</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="recentTable">
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 30px;">Loading...</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="recent-section" style="margin-top: 30px;">
                <h2 class="section-title">Top 10 Nearest Deadlines</h2>
                <table>
                    <thead>
                        <tr>
                            <th>Quotation No</th>
                            <th>Customer</th>
                            <th>Due Date</th>
                            <th>Remaining Days</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="deadlineTable">
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 30px;">Loading...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        async function loadDashboardData() {
            try {
                const response = await fetch('/api/workorder/list');
                const data = await response.json();

                if (data.success && data.data) {
                    const workOrders = data.data;

                    // Update stats
                    document.getElementById('totalOrders').textContent = workOrders.length;

                    const inProgress = workOrders.filter(wo => wo.status !== 'Completed').length;
                    const completedCount = workOrders.filter(wo => wo.status === 'Completed').length;

                    document.getElementById('inProgress').textContent = inProgress;
                    document.getElementById('completed').textContent = completedCount;

                    // Update recent table
                    const tbody = document.getElementById('recentTable');
                    tbody.innerHTML = '';

                    const recentOrders = workOrders.slice(0, 5);
                    recentOrders.forEach(wo => {
                        const row = document.createElement('tr');
                        const lastUpdate = new Date(wo.updated_at).toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'short',
                            day: 'numeric'
                        });

                        const statusClass = `status-${wo.status.toLowerCase().replace(/\s+/g, '-')}`;

                        row.innerHTML = `
                            <td>${wo.quotation_no}</td>
                            <td>${wo.customer_name}</td>
                            <td><span class="status-badge ${statusClass}">${wo.status}</span></td>
                            <td>${lastUpdate}</td>
                            <td><a href="/workorder?id=${wo.id}" class="action-btn">Edit</a></td>
                        `;
                        tbody.appendChild(row);
                    });

                    if (recentOrders.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="5" style="text-align: center; padding: 30px;">No work orders found</td></tr>';
                    }

                    const deadlineBody = document.getElementById('deadlineTable');
                    deadlineBody.innerHTML = '';

                    const today = new Date();
                    today.setHours(0, 0, 0, 0);

                    const urgentOrders = workOrders
                        .filter(wo => wo.status !== 'Completed' && wo.completion_date)
                        .map(wo => {
                            const deadline = new Date(wo.completion_date);
                            deadline.setHours(0, 0, 0, 0);
                            const remainingDays = Math.ceil((deadline - today) / (1000 * 60 * 60 * 24));
                            return { ...wo, remainingDays };
                        })
                        .sort((a, b) => a.remainingDays - b.remainingDays)
                        .slice(0, 10);

                    urgentOrders.forEach(wo => {
                        const row = document.createElement('tr');
                        const statusClass = `status-${wo.status.toLowerCase().replace(/\s+/g, '-')}`;
                        const completionDate = new Date(wo.completion_date).toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'short',
                            day: 'numeric'
                        });
                        const remainingText = wo.remainingDays < 0
                            ? `Overdue ${Math.abs(wo.remainingDays)} day(s)`
                            : `${wo.remainingDays} day(s)`;

                        row.innerHTML = `
                            <td>${wo.quotation_no}</td>
                            <td>${wo.customer_name}</td>
                            <td>${completionDate}</td>
                            <td>${remainingText}</td>
                            <td><span class="status-badge ${statusClass}">${wo.status}</span></td>
                        `;
                        deadlineBody.appendChild(row);
                    });

                    if (urgentOrders.length === 0) {
                        deadlineBody.innerHTML = '<tr><td colspan="5" style="text-align: center; padding: 30px;">No active work orders with due dates</td></tr>';
                    }
                }
            } catch (err) {
                console.error('Error loading dashboard data:', err);
                document.getElementById('recentTable').innerHTML = '<tr><td colspan="5" style="text-align: center; padding: 30px; color: red;">Error loading data</td></tr>';
                document.getElementById('deadlineTable').innerHTML = '<tr><td colspan="5" style="text-align: center; padding: 30px; color: red;">Error loading data</td></tr>';
            }
        }

        loadDashboardData();
        // Refresh data every 30 seconds
        setInterval(loadDashboardData, 30000);
    </script>
</body>

</html>