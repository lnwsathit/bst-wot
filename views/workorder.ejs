<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Work Order Management</title>
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css">
    <!-- Select2 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f5f7fa;
            color: #333;
        }

        .container {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 250px;
            background: white;
            box-shadow: 2px 0 8px rgba(0, 0, 0, 0.08);
            padding: 20px;
            position: fixed;
            height: 100vh;
            overflow-y: auto;
        }

        .sidebar-header {
            font-size: 18px;
            font-weight: 700;
            color: #667eea;
            margin-bottom: 30px;
            text-align: center;
        }

        .nav-item {
            display: block;
            padding: 12px 16px;
            margin-bottom: 8px;
            color: #666;
            text-decoration: none;
            border-radius: 8px;
            transition: all 0.3s;
            font-size: 14px;
        }

        .nav-item:hover {
            background: #f0f4ff;
            color: #667eea;
        }

        .nav-item.active {
            background: #667eea;
            color: white;
        }

        .nav-logout {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #e0e0e0;
        }

        .main-content {
            margin-left: 250px;
            flex: 1;
            padding: 30px;
        }

        .header {
            margin-bottom: 30px;
        }

        .header h1 {
            font-size: 28px;
            margin-bottom: 10px;
        }

        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            border-bottom: 2px solid #e0e0e0;
        }

        .tab-btn {
            padding: 12px 20px;
            background: none;
            border: none;
            color: #666;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            border-bottom: 3px solid transparent;
            transition: all 0.3s;
        }

        .tab-btn.active {
            color: #667eea;
            border-bottom-color: #667eea;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        .form-container {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }

        .form-section {
            margin-bottom: 25px;
            padding-bottom: 25px;
            border-bottom: 1px solid #e0e0e0;
        }

        .form-section:last-child {
            border-bottom: none;
        }

        .section-title {
            font-size: 16px;
            font-weight: 600;
            color: #333;
            margin-bottom: 15px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
        }

        label {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 6px;
            color: #333;
        }

        input[type="text"],
        input[type="number"],
        input[type="date"],
        select,
        textarea {
            padding: 10px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 14px;
            font-family: 'Segoe UI', sans-serif;
            transition: border-color 0.3s;
        }

        input[type="text"]:focus,
        input[type="number"]:focus,
        input[type="date"]:focus,
        select:focus,
        textarea:focus {
            outline: none;
            border-color: #667eea;
        }

        input[type="date"] {
            color: #333;
            background: #fff;
        }

        input[type="date"]::-webkit-calendar-picker-indicator {
            cursor: pointer;
        }

        textarea {
            resize: vertical;
            min-height: 80px;
        }

        .file-input-group {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        input[type="file"] {
            flex: 1;
        }

        .file-name {
            font-size: 12px;
            color: #666;
            margin-top: 4px;
        }

        .button-group {
            display: flex;
            gap: 10px;
            margin-top: 25px;
        }

        button {
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-submit {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
        }

        .btn-cancel {
            background: #e0e0e0;
            color: #666;
        }

        .btn-cancel:hover {
            background: #d0d0d0;
        }

        .table-container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: #f5f7fa;
        }

        th {
            padding: 15px;
            text-align: left;
            font-weight: 600;
            color: #666;
            border-bottom: 2px solid #e0e0e0;
            font-size: 13px;
        }

        td {
            padding: 15px;
            border-bottom: 1px solid #e0e0e0;
            font-size: 14px;
        }

        tbody tr:hover {
            background: #f9fafb;
        }

        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-quotation {
            background: #fff3cd;
            color: #856404;
        }

        .status-po-customer {
            background: #cfe2ff;
            color: #084298;
        }

        .status-po-supplier {
            background: #cff4fc;
            color: #055160;
        }

        .status-invoice {
            background: #d1e7dd;
            color: #0f5132;
        }

        .status-completed {
            background: #d1e7dd;
            color: #0f5132;
        }

        .action-btn {
            padding: 6px 12px;
            margin-right: 5px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.3s;
        }

        .btn-edit {
            background: #667eea;
            color: white;
        }

        .btn-edit:hover {
            background: #764ba2;
        }

        .btn-delete {
            background: #f8d7da;
            color: #721c24;
        }

        .btn-delete:hover {
            background: #f5c6cb;
        }

        .message {
            padding: 12px 16px;
            margin-bottom: 20px;
            border-radius: 8px;
            display: none;
        }

        .message.error {
            background: #fee;
            color: #c33;
            border-left: 4px solid #c33;
            display: block;
        }

        .message.success {
            background: #efe;
            color: #3c3;
            border-left: 4px solid #3c3;
            display: block;
        }

        @media (max-width: 768px) {
            .sidebar {
                display: none;
            }

            .main-content {
                margin-left: 0;
            }

            .form-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="sidebar">
            <div class="sidebar-header">📊 WOT System</div>
            <a href="/dashboard" class="nav-item">Dashboard</a>
            <a href="/workorder" class="nav-item active">Work Orders</a>
            <% if (user.role==='Admin' ) { %>
                <a href="/customers" class="nav-item">Customer Management</a>
                <a href="/users" class="nav-item">Users Management</a>
                <% } %>
                    <div class="nav-logout">
                        <a href="/api/auth/logout" class="nav-item">Logout</a>
                    </div>
        </div>

        <div class="main-content">
            <div class="header">
                <h1>Work Order Management</h1>
            </div>

            <div class="tabs">
                <button class="tab-btn active" onclick="switchTab('list-tab')">📋 Work Orders List</button>
                <button class="tab-btn" onclick="switchTab('create-tab')">➕ Create New</button>
            </div>

            <!-- List Tab -->
            <div id="list-tab" class="tab-content active">
                <div id="message" class="message"></div>
                <div class="table-container">
                    <table id="workorders">
                        <thead>
                            <tr>
                                <th>Quotation No</th>
                                <th>Customer</th>
                                <th>Status</th>
                                <th>Due Date</th>
                                <th>Remaining Days</th>
                                <th>Last Update</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="listTable">
                            <tr>
                                <td>Loading...</td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Create Tab -->
            <div id="create-tab" class="tab-content">
                <div class="form-container">
                    <form id="workOrderForm" enctype="multipart/form-data">
                        <input type="hidden" id="woId" name="woId">

                        <!-- Customer Information -->
                        <div class="form-section">
                            <div class="section-title">Customer Information</div>
                            <div class="form-grid">
                                <div class="form-group">
                                    <label>Customer Name *</label>
                                    <select name="customer_name" id="customerSelect" required style="width: 100%;">
                                        <option value="">Select a customer...</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Quotation -->
                        <div class="form-section">
                            <div class="section-title">📄 Quotation</div>
                            <div class="form-grid">
                                <div class="form-group">
                                    <label>Quotation Number *</label>
                                    <input type="text" name="quotation_no" required>
                                </div>
                                <div class="form-group">
                                    <label>Detail (max 30 chars)</label>
                                    <input type="text" name="quotation_detail" maxlength="30"
                                        placeholder="e.g., Quotation created by sales">
                                </div>
                                <div class="form-group">
                                    <label>Quotation PDF</label>
                                    <input type="file" name="quotation_file" accept=".pdf">
                                    <div class="file-name" id="quotation_file_name"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Customer PO -->
                        <div class="form-section">
                            <div class="section-title">📋 Customer PO</div>
                            <div class="form-grid">
                                <div class="form-group">
                                    <label>Customer PO Number</label>
                                    <input type="text" name="po_customer_no">
                                </div>
                                <div class="form-group">
                                    <label>Detail (max 30 chars)</label>
                                    <input type="text" name="po_customer_detail" maxlength="30"
                                        placeholder="e.g., Customer confirmed order">
                                </div>
                                <div class="form-group">
                                    <label>Customer PO PDF</label>
                                    <input type="file" name="po_customer_file" accept=".pdf">
                                    <div class="file-name" id="po_customer_file_name"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Supplier PO -->
                        <div class="form-section">
                            <div class="section-title">📦 Supplier PO</div>
                            <div class="form-grid">
                                <div class="form-group">
                                    <label>Supplier PO Number</label>
                                    <input type="text" name="po_supplier_no">
                                </div>
                                <div class="form-group">
                                    <label>Detail (max 30 chars)</label>
                                    <input type="text" name="po_supplier_detail" maxlength="30"
                                        placeholder="e.g., Purchase order to supplier">
                                </div>
                                <div class="form-group">
                                    <label>Supplier PO PDF</label>
                                    <input type="file" name="po_supplier_file" accept=".pdf">
                                    <div class="file-name" id="po_supplier_file_name"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Invoice -->
                        <div class="form-section">
                            <div class="section-title">🧾 Invoice</div>
                            <div class="form-grid">
                                <div class="form-group">
                                    <label>Invoice Number</label>
                                    <input type="text" name="invoice_no">
                                </div>
                                <div class="form-group">
                                    <label>Detail (max 30 chars)</label>
                                    <input type="text" name="invoice_detail" maxlength="30"
                                        placeholder="e.g., Sales issued billing invoice">
                                </div>
                                <div class="form-group">
                                    <label>Invoice PDF</label>
                                    <input type="file" name="invoice_file" accept=".pdf">
                                    <div class="file-name" id="invoice_file_name"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Status -->
                        <div class="form-section">
                            <div class="section-title">Status</div>
                            <div class="form-grid">
                                <div class="form-group">
                                    <label>Due Date</label>
                                    <input type="date" name="completion_date">
                                </div>
                                <div class="form-group">
                                    <label>Current Status</label>
                                    <select name="status" required>
                                        <option value="Quotation">Quotation</option>
                                        <option value="Customer PO">Customer PO</option>
                                        <option value="Supplier PO">Supplier PO</option>
                                        <option value="Invoice">Invoice</option>
                                        <option value="Completed">Completed</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="button-group">
                            <button type="submit" class="btn-submit">Save Work Order</button>
                            <button type="button" class="btn-cancel" onclick="resetForm()">Clear</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- jQuery & DataTables JS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <!-- Select2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        function switchTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('active');
            });
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            document.getElementById(tabName).classList.add('active');
            event.target.classList.add('active');
        }

        function resetForm() {
            document.getElementById('workOrderForm').reset();
            document.getElementById('woId').value = '';
            document.querySelectorAll('.file-name').forEach(el => el.textContent = '');
            $('#customerSelect').val('').trigger('change');
        }

        async function loadWorkOrders() {
            try {
                const response = await fetch('/api/workorder/list');
                const data = await response.json();

                if (data.success) {
                    const tbody = document.getElementById('listTable');
                    tbody.innerHTML = '';

                    data.data.forEach(wo => {
                        const row = document.createElement('tr');
                        const lastUpdate = new Date(wo.updated_at).toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'short',
                            day: 'numeric'
                        });
                        const completionDate = wo.completion_date
                            ? new Date(wo.completion_date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
                            : '-';
                        const remainingDays = getRemainingDays(wo.completion_date);

                        const statusClass = `status-${wo.status.toLowerCase().replace(/\s+/g, '-')}`;

                        row.innerHTML = `
                            <td>${wo.quotation_no}</td>
                            <td>${wo.customer_name}</td>
                            <td><span class="status-badge ${statusClass}">${wo.status}</span></td>
                            <td>${completionDate}</td>
                            <td>${remainingDays}</td>
                            <td>${lastUpdate}</td>
                            <td>
                                <button type="button" class="action-btn btn-edit" onclick="editWorkOrder(${wo.id})">Edit</button>
                                <% if (user.role === 'Admin') { %>
                                    <button type="button" class="action-btn btn-delete" onclick="deleteWorkOrder(${wo.id})">Delete</button>
                                <% } %>
                            </td>
                        `;
                        tbody.appendChild(row);
                    });

                    if (data.data.length === 0) {
                        tbody.innerHTML = '<tr><td>No work orders found</td><td></td><td></td><td></td><td></td><td></td><td></td></tr>';
                    }

                    // apply or refresh DataTable
                    if ($.fn.DataTable.isDataTable('#workorders')) {
                        $('#workorders').DataTable().destroy();
                    }
                    $('#workorders').DataTable({
                        pageLength: 10,
                        order: [[0, 'asc']],
                        columnDefs: [
                            { orderable: false, targets: 6 } // disable ordering on actions column
                        ]
                    });
                }
            } catch (err) {
                console.error('Error loading work orders:', err);
            }
        }

        function getRemainingDays(completionDate) {
            if (!completionDate) return '-';
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            const deadline = new Date(completionDate);
            deadline.setHours(0, 0, 0, 0);
            const diffMs = deadline - today;
            const days = Math.ceil(diffMs / (1000 * 60 * 60 * 24));
            if (days < 0) return `Overdue ${Math.abs(days)} day(s)`;
            return `${days} day(s)`;
        }

        async function editWorkOrder(id) {
            try {
                const response = await fetch(`/api/workorder/${id}`);
                const data = await response.json();

                if (data.success) {
                    const wo = data.data;
                    document.getElementById('woId').value = wo.id;
                    $('#customerSelect').val(wo.customer_name).trigger('change');
                    document.querySelector('input[name="quotation_no"]').value = wo.quotation_no;
                    document.querySelector('input[name="quotation_detail"]').value = wo.quotation_detail || '';
                    document.querySelector('input[name="po_customer_no"]').value = wo.po_customer_no || '';
                    document.querySelector('input[name="po_customer_detail"]').value = wo.po_customer_detail || '';
                    document.querySelector('input[name="po_supplier_no"]').value = wo.po_supplier_no || '';
                    document.querySelector('input[name="po_supplier_detail"]').value = wo.po_supplier_detail || '';
                    document.querySelector('input[name="invoice_no"]').value = wo.invoice_no || '';
                    document.querySelector('input[name="invoice_detail"]').value = wo.invoice_detail || '';
                    document.querySelector('input[name="completion_date"]').value = wo.completion_date ? wo.completion_date.split('T')[0] : '';
                    document.querySelector('select[name="status"]').value = wo.status;

                    if (wo.quotation_file) document.getElementById('quotation_file_name').textContent = `Current: ${wo.quotation_file}`;
                    if (wo.po_customer_file) document.getElementById('po_customer_file_name').textContent = `Current: ${wo.po_customer_file}`;
                    if (wo.po_supplier_file) document.getElementById('po_supplier_file_name').textContent = `Current: ${wo.po_supplier_file}`;
                    if (wo.invoice_file) document.getElementById('invoice_file_name').textContent = `Current: ${wo.invoice_file}`;

                    switchTab('create-tab');
                }
            } catch (err) {
                console.error('Error editing work order:', err);
            }
        }

        async function deleteWorkOrder(id) {
            if (!confirm('Are you sure you want to delete this work order?')) return;

            try {
                const response = await fetch(`/api/workorder/delete/${id}`, {
                    method: 'DELETE'
                });
                const data = await response.json();

                if (data.success) {
                    showMessage('Work order deleted successfully', 'success');
                    loadWorkOrders();
                } else {
                    showMessage(data.error, 'error');
                }
            } catch (err) {
                console.error('Error deleting work order:', err);
                showMessage('Error deleting work order', 'error');
            }
        }

        function showMessage(text, type) {
            const msgEl = document.getElementById('message');
            msgEl.textContent = text;
            msgEl.className = `message ${type}`;
            setTimeout(() => {
                msgEl.className = 'message';
            }, 5000);
        }

        document.getElementById('workOrderForm').addEventListener('submit', async function (e) {
            e.preventDefault();

            const woId = document.getElementById('woId').value;
            const endpoint = woId ? `/api/workorder/update/${woId}` : '/api/workorder/create';

            try {
                const formData = new FormData(this);
                formData.delete('woId');

                const response = await fetch(endpoint, {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (data.success) {
                    alert(data.message || 'Work order saved successfully');
                    window.location.href = '/workorder';
                } else {
                    showMessage(data.error, 'error');
                }
            } catch (err) {
                console.error('Error saving work order:', err);
                showMessage('Error saving work order', 'error');
            }
        });

        // Initialize Select2 for customer dropdown
        async function loadCustomers() {
            try {
                const response = await fetch('/api/customers/options');
                const data = await response.json();

                if (data.success) {
                    const select = $('#customerSelect');
                    select.empty();
                    select.append('<option value="">Select a customer...</option>');

                    data.data.forEach(customer => {
                        select.append(`<option value="${customer.name}">${customer.name}</option>`);
                    });
                }
            } catch (err) {
                console.error('Error loading customers:', err);
            }
        }

        $(document).ready(function () {
            $('#customerSelect').select2({
                placeholder: 'Select a customer...',
                allowClear: true
            });
        });

        // Initialize
        loadWorkOrders();
        loadCustomers();
    </script>
</body>

</html>